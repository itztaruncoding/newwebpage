    "text": "return <div className=\"min-h-screen flex flex-col bg-background\">{<Navbar />}{<main className=\"flex-1 pt-32 pb-20\">{<div className=\"container mx-auto px-4 md:px-6 max-w-6xl\">{<div className=\"flex items-center gap-2 text-sm text-muted-foreground mb-8 font-medium\">{<Link href=\"/\" className=\"hover:text-primary\">Home</Link>}{<span>/</span>}{<Link href=\"/deals\" className=\"hover:text-primary\">Deals</Link>}{<span>/</span>}{<span className=\"text-foreground\">{deal.name}</span>}</div>}{<div className=\"grid grid-cols-1 lg:grid-cols-3 gap-12\">{<div className=\"lg:col-span-2 space-y-12\">{<div className=\"flex flex-col sm:flex-row gap-6 items-start sm:items-center\">{<div className=\"w-24 h-24 rounded-2xl border border-border bg-card p-4 flex items-center justify-center shrink-0 shadow-sm\">{<img src={deal.logo} alt={deal.name} className=\"w-full h-full object-contain\" />}</div>}{<div>{<div className=\"flex items-center gap-3 mb-2\">{<h1 className=\"text-4xl md:text-5xl font-black\">{deal.name}</h1>}{<span className=\"bg-blue-50 text-blue-700 font-bold px-3 py-1 rounded-full text-sm\">{deal.discountBadge}</span>}</div>}{<p className=\"text-xl text-muted-foreground mb-3\">{deal.tagline}</p>}{<div className=\"flex items-center gap-4\">{<div className=\"flex items-center gap-1\">{<Star className=\"w-5 h-5 fill-secondary text-secondary\" />}{<span className=\"font-bold text-lg\">{deal.rating}</span>}{<span className=\"text-muted-foreground\">({deal.reviewCount} reviews)</span>}</div>}{<span className=\"w-1 h-1 rounded-full bg-border\" />}{<span className=\"text-primary font-semibold\">{deal.category}</span>}</div>}</div>}</div>}{<section>{<h2 className=\"text-2xl font-bold mb-4\">About {deal.name}</h2>}{<div className=\"prose prose-lg text-muted-foreground\">{deal.description.map((paragraph, i) => <p className=\"mb-4 leading-relaxed\">{paragraph}</p>)}</div>}</section>}{<section>{<h2 className=\"text-2xl font-bold mb-4\">What's Included in this Deal</h2>}{<div className=\"grid grid-cols-1 sm:grid-cols-2 gap-4\">{deal.features.map((feature, i) => <div className=\"flex items-start gap-3 bg-card border border-border p-4 rounded-xl shadow-sm\">{<CheckCircle className=\"w-5 h-5 text-primary shrink-0 mt-0.5\" />}{<span className=\"font-medium\">{feature}</span>}</div>)}</div>}</section>}{<section className=\"grid sm:grid-cols-2 gap-6\">{<div className=\"bg-blue-50/70 border border-blue-100 rounded-xl p-6\">{<h3 className=\"text-lg font-bold text-blue-800 mb-4 flex items-center gap-2\">{<ThumbsUp className=\"w-5 h-5\" />} Pros</h3>}{<ul className=\"space-y-3\">{deal.pros.map((pro, i) => <li className=\"flex items-start gap-2 text-blue-700\">{<CheckCircle className=\"w-4 h-4 shrink-0 mt-1\" />}{<span>{pro}</span>}</li>)}</ul>}</div>}{<div className=\"bg-blue-50/70 border border-blue-100 rounded-xl p-6\">{<h3 className=\"text-lg font-bold text-blue-800 mb-4 flex items-center gap-2\">{<ThumbsDown className=\"w-5 h-5\" />} Cons</h3>}{<ul className=\"space-y-3\">{deal.cons.map((con, i) => <li className=\"flex items-start gap-2 text-blue-700\">{<span className=\"w-1.5 h-1.5 rounded-full bg-blue-400 shrink-0 mt-2\" />}{<span>{con}</span>}</li>)}</ul>}</div>}</section>}{<section>{<h2 className=\"text-2xl font-bold mb-6\">User Reviews</h2>}{<div className=\"space-y-4\">{deal.reviews.map((review, i) => <div className=\"bg-card border border-border p-6 rounded-xl shadow-sm\">{<div className=\"flex items-center justify-between mb-3\">{<div className=\"flex items-center gap-3\">{<div className=\"w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center font-bold\">{review.author.charAt(0)}</div>}{<div>{<p className=\"font-bold\">{review.author}</p>}{<p className=\"text-xs text-muted-foreground\">{review.date}</p>}</div>}</div>}{<div className=\"flex gap-0.5\">{[...Array(5)].map((_, starIdx) => <Star className={`w-4 h-4 ${starIdx < review.rating ? \"fill-secondary text-secondary\" : \"fill-muted text-muted\"}`} />)}</div>}</div>}{<p className=\"text-foreground\">{review.text}</p>}</div>)}</div>}</section>}</div>}{<div className=\"lg:col-span-1\">{<div className=\"sticky top-28 bg-card border border-border rounded-2xl p-6 shadow-xl\">{<div className=\"mb-6\">{<p className=\"text-sm font-bold text-destructive mb-2 uppercase tracking-wide\">Limited Time Offer</p>}{<CountdownTimer hours={deal.timerHours} mins={deal.timerMins} />}</div>}{<div className=\"border-t border-b border-border py-6 mb-6\">{<div className=\"flex items-center justify-between mb-2\">{<span className=\"text-muted-foreground\">Original Price</span>}{<span className=\"line-through\">{deal.originalPrice}</span>}</div>}{<div className=\"flex items-center justify-between mb-4\">{<span className=\"text-muted-foreground\">Discount</span>}{<span className=\"text-blue-700 font-bold\">-{deal.discountPercentage}%</span>}</div>}{<div className=\"flex items-center justify-between mt-4 pt-4 border-t border-border border-dashed\">{<span className=\"font-bold text-lg\">Sale Price</span>}{<div className=\"text-right\">{<span className=\"text-3xl font-black block text-foreground\">{deal.salePrice}</span>}</div>}</div>}</div>}{<a href=\"#\" className=\"w-full flex items-center justify-center gap-2 bg-primary text-primary-foreground font-black text-lg py-4 rounded-xl hover:bg-primary/90 transition-all shadow-lg hover:shadow-primary/30 hover:-translate-y-1 mb-4\">Get This Deal {<ExternalLink className=\"w-5 h-5\" />}</a>}{<ul className=\"text-sm text-muted-foreground space-y-2 text-center\">{<li>\u2714 Includes 30-day money-back guarantee</li>}{<li>\u2714 Instant account activation</li>}{<li>\u2714 Secure SSL encrypted checkout</li>}</ul>}</div>}</div>}</div>}{<div className=\"mt-24 pt-16 border-t border-border\">{<div className=\"flex items-center justify-between mb-8\">{<h2 className=\"text-3xl font-bold\">Related Deals</h2>}{<Link href=\"/deals\" className=\"text-primary font-semibold hover:underline hidden sm:block\">View all deals \u2192</Link>}</div>}{<div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">{relatedDeals.map((d, i) => <DealCard deal={d} index={i} />)}</div>}</div>}</div>}</main>}{<Footer />}</div>;",
